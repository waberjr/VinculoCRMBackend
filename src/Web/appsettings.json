{
  "ConnectionStrings": {
    "VinculoBackendDb": "Server=127.0.0.1;Port=3306;Database=VinculoBackendDb;User=admin;Password=password;"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "https://localhost:4200",
    ]
  },
  "FileStorage": {
    "ConnectionString": "UseDevelopmentStorage=true",
    "ContainerName": "vinculo-documents",
    "ServiceVersion": "V2024_11_04"
  },
  "DocumentUpload": {
    "MaxFileSizeBytes": 10485760,
    "AllowedExtensions": [ ".pdf", ".png", ".jpg", ".jpeg", ".doc", ".docx", ".xls", ".xlsx", ".csv", ".txt" ],
    "AllowedContentTypes": [
      "application/pdf",
      "image/png",
      "image/jpeg",
      "application/msword",
      "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
      "application/vnd.ms-excel",
      "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
      "text/csv",
      "text/plain"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
